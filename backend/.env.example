# Application
APP_NAME=Agente de Procesos BPMN
APP_VERSION=1.1.2
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-key-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agente_procesos

# Google Gemini (única configuración de IA)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=process_documents

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS — URL del frontend en Vercel (sin barra final)
FRONTEND_URL=
CORS_ORIGINS=["http://localhost:3000"]
