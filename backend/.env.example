# Application
APP_NAME=Agente de Procesos BPMN
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-key-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agente_procesos

# OpenAI
# Proveedor IA: gemini | openai
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# OpenAI (opcional)
OPENAI_API_KEY=

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=process_documents

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:3000"]
